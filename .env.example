# Database (Neon PostgreSQL recommended for Vercel)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="change-me-use-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-app.vercel.app"

# Admin credentials (used by seed script)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Storage driver: db (default, stores in PostgreSQL) or s3
STORAGE_DRIVER="db"

# S3 settings (only when STORAGE_DRIVER=s3)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""

# Render worker
RENDER_CONCURRENCY="2"

# App
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
