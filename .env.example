# Database
# Local (Docker):
DATABASE_URL="postgresql://photobooth:photobooth@localhost:5432/photobooth?schema=public"
# Neon (Production):
# DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Storage (local or s3)
STORAGE_DRIVER="local"
# S3 settings (only when STORAGE_DRIVER=s3)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""

# Render worker
RENDER_CONCURRENCY="2"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
